#!/bin/bash
#
# Provision data sync for ~/.claude via `rcloneops claude-bootstrap`.
#
# Marketplace + plugin configuration is handled separately and earlier, by
# ensure-compusib-marketplace on postStart (declarative, jq-only, no `claude`
# binary). This script only provisions data sync.
#
# Designed to run from the feature's postAttachCommand. Never fails the attach.

set -uo pipefail

CONFIG_FILE="${FEATURE_LIB_DIR:-/usr/local/lib/features}/claude/config.env"

# Defaults; overridden by config.env written at install time.
BOOTSTRAP_CLAUDE_SYNC="true"
# shellcheck source=/dev/null
[[ -f "$CONFIG_FILE" ]] && . "$CONFIG_FILE"

log() { echo "🔧 [bootstrap-claude-sync] $*"; }

# Lifecycle hooks run via `/bin/sh -c` — a non-interactive, non-login shell that
# never sources ~/.bashrc, so the PATH fragments the bashrc feature writes into
# ~/.bashrc.d/*.sh (where `claude` and `rcloneops` come from) are not applied.
# Source those fragments directly: sourcing ~/.bashrc itself is unreliable since
# the stock file returns early for non-interactive shells before its .bashrc.d
# loop runs. Tolerant of fragments that assume `set -u` is off or emit noise.
load_bashrc_path() {
    local frag
    [[ -d "$HOME/.bashrc.d" ]] || return 0
    set +u
    shopt -s nullglob
    for frag in "$HOME"/.bashrc.d/*.sh; do
        # shellcheck source=/dev/null
        . "$frag" >/dev/null 2>&1 || true
    done
    shopt -u nullglob
    set -u
}
load_bashrc_path

# Provision data sync for ~/.claude via rcloneops. Skipped when disabled or when
# rcloneops is absent (it ships with the bashrc feature's bash repo).
bootstrap_sync() {
    if [[ "$BOOTSTRAP_CLAUDE_SYNC" != "true" ]]; then
        log "bootstrapClaudeSync=false — skipping data sync."
        return 0
    fi
    if ! command -v rcloneops >/dev/null 2>&1; then
        log "⚠️  'rcloneops' not on PATH; skipping Claude data sync bootstrap."
        return 0
    fi

    log "running 'rcloneops claude-bootstrap' (bisync baseline)."
    rcloneops claude-bootstrap --no-dry-run \
        || log "⚠️  'rcloneops claude-bootstrap' returned non-zero (missing B2 credentials?)."
}

bootstrap_sync
log "✅ done."
exit 0
