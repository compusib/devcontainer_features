#!/bin/bash
# Install CLAUDE_PLUGINS (+ their full dependency closure) via the claude CLI,
# from one or more marketplaces. Invoked by claude-process-wrapper with the
# session's binary in CLAUDE_BIN (else resolves one). No jq for marketplace/plugin
# state: the CLI owns it. Never fails caller.
#
# Marketplaces come from PLUGIN_MARKETPLACES — space-separated 'name|source[|override]'
# entries (name = the @<marketplace> suffix plugins reference). A local override wins
# only when it holds .claude-plugin/marketplace.json, else the git source is used.
#
# `claude plugin install X` resolves X's direct deps, but a dep it auto-installs
# gets only its FIRST dep (2.1.143–2.1.177; docs claim transitive — see
# anthropics/claude-code#68449). So install the roots, then re-install each
# installed plugin explicitly (with its own @<marketplace> as the source), looping
# until none are new (base-stack -> base -> rclone, ...).

set -uo pipefail

RUNTIME_LIB_DIR="${FEATURE_LIB_DIR:-/usr/local/lib/features}/claude"
CONFIG_FILE="${RUNTIME_LIB_DIR}/config.env"
PLUGIN_MARKETPLACES="compusib|git@github.com:compusib/ai.git|/workspace/compusib/ai addy-agent-skills|git@github.com:paulbalomiri/agent-skills.git|/workspace/paulbalomiri/agent-skills"
CLAUDE_PLUGINS=""
DEFAULT_PLUGIN_CONFIGS="true"
# shellcheck source=/dev/null
[[ -f "$CONFIG_FILE" ]] && . "$CONFIG_FILE"

log() { echo "🔧 [ensure-marketplace-recursively-installed] $*"; }

# The single-plugin install operation (seed userConfig defaults, then install)
# lives in a sourced lib — prepwork for moving the runtime scripts into the bash
# repo. Fall back to a plain install if the lib is not present.
# shellcheck source=/dev/null
[[ -f "${RUNTIME_LIB_DIR}/plugin-install.sh" ]] && . "${RUNTIME_LIB_DIR}/plugin-install.sh"
declare -F install_plugin >/dev/null 2>&1 \
    || install_plugin() { "$1" plugin install "$2" >/dev/null 2>&1; }

[[ -z "$CLAUDE_PLUGINS" ]] && exit 0

# Parse PLUGIN_MARKETPLACES into name -> source / override maps. Entries are
# space-separated 'name|source[|override]'; git URLs and paths hold no spaces, so a
# plain word-split is safe. Bad entries (missing name or source) are skipped.
declare -A MP_SOURCE MP_OVERRIDE
for entry in $PLUGIN_MARKETPLACES; do
    IFS='|' read -r mp_name mp_src mp_ovr <<< "$entry"
    [[ -n "$mp_name" && -n "$mp_src" ]] || { log "⚠️  bad marketplace entry '${entry}'; skipping."; continue; }
    MP_SOURCE["$mp_name"]="$mp_src"
    MP_OVERRIDE["$mp_name"]="${mp_ovr:-}"
done
[[ "${#MP_SOURCE[@]}" -gt 0 ]] || { log "⚠️  no usable marketplaces; skipping."; exit 0; }

# Resolve claude: prefer CLAUDE_BIN (wrapper), else PATH / ~/.local/bin / a
# ~/.bashrc.d sweep (lifecycle hooks run via /bin/sh -c, no ~/.bashrc).
resolve_claude() {
    command -v claude 2>/dev/null && return 0
    [[ -x "${HOME}/.local/bin/claude" ]] && { printf '%s\n' "${HOME}/.local/bin/claude"; return 0; }
    [[ -d "$HOME/.bashrc.d" ]] && { set +u; shopt -s nullglob
        for f in "$HOME"/.bashrc.d/*.sh; do . "$f" >/dev/null 2>&1 || true; done
        shopt -u nullglob; set -u; }
    command -v claude 2>/dev/null
}
if [[ -n "${CLAUDE_BIN:-}" && -x "${CLAUDE_BIN}" ]]; then :; else
    CLAUDE_BIN="$(resolve_claude)" || { log "⚠️  claude not found; skipping."; exit 0; }
fi

# Resolve each marketplace's effective source: its local override wins only if that
# directory holds a manifest, else the git source. `marketplace add` is idempotent
# and re-clones on a flip, so no cache pruning needed.
declare -A MP_RESOLVED
for mp_name in "${!MP_SOURCE[@]}"; do
    ovr="${MP_OVERRIDE[$mp_name]}"
    if [[ -n "$ovr" && -f "${ovr%/}/.claude-plugin/marketplace.json" ]]; then
        MP_RESOLVED["$mp_name"]="${ovr%/}"
    else
        MP_RESOLVED["$mp_name"]="${MP_SOURCE[$mp_name]}"
    fi
done

# Sentinel: runs every launch, but the work is needed once per (plugins, every
# resolved source, version). Skip when unchanged so steady-state launches are
# instant. Host-local. Sources are name-sorted so the signature is order-stable.
sources_sig=""
while IFS= read -r mp_name; do
    sources_sig="${sources_sig}${mp_name}=${MP_RESOLVED[$mp_name]};"
done <<< "$(printf '%s\n' "${!MP_RESOLVED[@]}" | sort)"
SENTINEL="${HOME}/.claude/.plugins-ensured"
sig="${CLAUDE_PLUGINS}|${sources_sig}|$("$CLAUDE_BIN" --version 2>/dev/null || echo '?')"
[[ -f "$SENTINEL" && "$(cat "$SENTINEL" 2>/dev/null)" == "$sig" ]] && exit 0

# Register every marketplace.
for mp_name in "${!MP_RESOLVED[@]}"; do
    log "marketplace ${mp_name} source: ${MP_RESOLVED[$mp_name]}"
    "$CLAUDE_BIN" plugin marketplace add "${MP_RESOLVED[$mp_name]}" 2>&1 | sed 's/^/    /' || true
    "$CLAUDE_BIN" plugin marketplace update "$mp_name" >/dev/null 2>&1 || true
done

# Match installed plugins from any of our marketplaces (regex alternation of names).
mp_alt="$(printf '%s|' "${!MP_RESOLVED[@]}")"; mp_alt="${mp_alt%|}"
installed_plugins() { "$CLAUDE_BIN" plugin list 2>/dev/null | grep -oE "[a-z0-9-]+@(${mp_alt})" | sort -u; }

# Each plugin carries its own @<marketplace> suffix — install/re-install it against
# that marketplace (so seeded defaults resolve from the right manifest cache).
seen=" "
for plugin in $CLAUDE_PLUGINS; do
    install_plugin "$CLAUDE_BIN" "$plugin" "${plugin##*@}" || log "⚠️  install ${plugin} failed."
    seen="${seen}${plugin} "
done

pass=0
while :; do
    pass=$((pass + 1)); progressed=0
    while IFS= read -r plugin; do
        [[ -n "$plugin" ]] || continue
        case "$seen" in *" ${plugin} "*) continue ;; esac
        seen="${seen}${plugin} "
        install_plugin "$CLAUDE_BIN" "$plugin" "${plugin##*@}" || true
        progressed=1
    done <<< "$(installed_plugins)"
    [[ "$progressed" -eq 0 ]] && break
    [[ "$pass" -ge 10 ]] && { log "⚠️  deps unsettled after ${pass} passes."; break; }
done

printf '%s' "$sig" > "$SENTINEL" 2>/dev/null || true
log "✅ installed: $(installed_plugins | tr '\n' ' ')"

# Editor reload signal. The Claude extension builds its slash-command/skill index
# at activation — BEFORE this wrapper runs — so freshly installed plugins aren't
# registered until the extension host restarts. We can't restart it from bash, so
# we write the LOGICAL plugin-config hash (id/version/scope/enabled — stable across
# idempotent reinstalls) to a file settings-bridge watches, and ONLY when it
# changed. That fires the restart exactly once per real change and never loops on a
# no-op reinstall. We are authoritative here: we hold the matching claude binary and
# just finished installing. Best-effort; jq is already required by the seed step.
if command -v jq >/dev/null 2>&1; then
    hash_file="${HOME}/.claude/.plugin-config-hash"
    plugins_json="$("$CLAUDE_BIN" plugin list --json 2>/dev/null || true)"
    if [[ -n "$plugins_json" ]]; then
        new_hash="$(printf '%s' "$plugins_json" \
            | jq -cS 'sort_by(.id) | map({id, version, scope, enabled})' 2>/dev/null \
            | sha256sum | cut -d' ' -f1)"
        if [[ -n "$new_hash" && "$new_hash" != "$(cat "$hash_file" 2>/dev/null || true)" ]]; then
            printf '%s\n' "$new_hash" >"$hash_file" 2>/dev/null \
                && log "plugin-config changed -> ${hash_file} (settings-bridge reloads the extension host)"
        fi
    fi
fi
exit 0
