#!/bin/bash
#
# Ensure the compusib.settings-bridge *.vsix is present at the canonical path the
# feature's customizations.vscode.extensions points at, so VS Code installs the
# extension ITSELF, declaratively, at connect — no `code` CLI, no remote-cli, no
# $VSCODE_IPC_HOOK_CLI (which hardened containers strip).
#
# The extension is installed IN PLACE from wherever the vsix already lives — it is
# never copied or symlinked into a staging dir:
#   1. Local working tree (e.g. bind-mounted /workspace/compusib/ai): used as-is.
#   2. Otherwise: a shallow + sparse CHECKOUT of compusib/ai into that SAME canonical
#      path, materializing only the vsix dir. Never clones over an existing repo.
#
# customizations.vscode.extensions names a fixed, version-less path
# (.../dist/compusib.settings-bridge.vsix — the extension build emits that stable
# name), so this script only has to guarantee the checkout exists there.
#
# Runs from onCreateCommand: the workspace is set up and it is BEFORE extensions are
# configured (the vsix must exist by attach). Never fails startup.

set -euo pipefail

CONFIG_FILE="${FEATURE_LIB_DIR:-/usr/local/lib/features}/claude/config.env"

# Defaults (overridden by the feature config written at install time).
INSTALL_SETTINGS_BRIDGE="true"
SETTINGS_BRIDGE_REPO_PATH="/workspace/compusib/ai"
SETTINGS_BRIDGE_REPO="git@github.com:compusib/ai.git"
SETTINGS_BRIDGE_REF="main"
SETTINGS_BRIDGE_VSIX_DIR="vscode/settings-bridge/dist"
VSIX_NAME="compusib.settings-bridge.vsix"
# shellcheck source=/dev/null
[[ -f "$CONFIG_FILE" ]] && . "$CONFIG_FILE"

log() { echo "🔧 [settings-bridge] $*"; }

if [[ "$INSTALL_SETTINGS_BRIDGE" != "true" ]]; then
    log "installSettingsBridge is disabled, skipping."
    exit 0
fi

repo="${SETTINGS_BRIDGE_REPO_PATH%/}"
vsix="${repo}/${SETTINGS_BRIDGE_VSIX_DIR##/}/${VSIX_NAME}"

# 1) Already present (mounted working tree, or a checkout from a prior run) -> use in
#    place. No copy, no symlink — customizations.vscode.extensions points right here.
if [[ -f "$vsix" ]]; then
    log "✅ ${VSIX_NAME} present at ${vsix} (VS Code installs it via customizations.vscode.extensions)"
    exit 0
fi

# 2) The repo dir exists but holds no vsix -> never clone over it. A dev working tree
#    just needs to be built; the declarative install no-ops until then.
if [[ -d "$repo" ]]; then
    log "⚠️  ${repo} exists but ${SETTINGS_BRIDGE_VSIX_DIR##/}/${VSIX_NAME} is missing — not cloning over an existing repo. Build it with vscode/settings-bridge/build.sh."
    exit 0
fi

# 3) No working tree -> sparse + shallow CHECKOUT into the canonical path, so the vsix
#    lands exactly where customizations.vscode.extensions expects it. accept-new
#    auto-trusts github on first contact; auth uses the forwarded SSH agent / helper.
log "checking out ${SETTINGS_BRIDGE_REPO} (${SETTINGS_BRIDGE_REF}) -> ${repo} (sparse: ${SETTINGS_BRIDGE_VSIX_DIR##/})"
mkdir -p "$(dirname "$repo")"
if ! GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o StrictHostKeyChecking=accept-new}" \
        git clone --depth 1 --branch "$SETTINGS_BRIDGE_REF" --filter=blob:none --sparse \
            "$SETTINGS_BRIDGE_REPO" "$repo"; then
    log "⚠️  checkout failed; removing partial ${repo}."
    rm -rf "$repo"
    exit 0
fi
git -C "$repo" sparse-checkout set "$SETTINGS_BRIDGE_VSIX_DIR" || true

if [[ -f "$vsix" ]]; then
    log "✅ checked out ${VSIX_NAME} -> ${vsix} (VS Code installs it via customizations.vscode.extensions)"
else
    log "⚠️  checkout completed but ${vsix} not found — nothing to install."
fi
exit 0
