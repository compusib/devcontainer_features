{
    "id": "bashrc",
    "version": "0.0.8",
    "name": "bashrc",
    "documentationURL": "https://github.com/compusib/devcontainer_features/src/bashrc/README.md",
    "description": "set startup options",
    "options": {
        "version": {
            "default": "latest",
            "description": "Select the version to install.",
            "proposals": [
                "latest"
            ],
            "type": "string"
        },
        "gitRoot": {
            "default": "\\$CONTAINER_WORKSPACE_FOLDER",
            "type": "string",
            "description": "Where the root of the git directory is located. Defaults to the value of the workspace folder"
        },
        "pathAppend": {
            "default": "\\$CONTAINER_WORKSPACE_FOLDER/scripts",
            "type": "string",
            "description": "Appends this Path to the container PATH environment variable using ~/.bashrc.d/100_bash_path_append.sh"
        },
        "compusibBashRepoRoot": {
            "default": "/workspace/compusib/bash",
            "type": "string",
            "description": "Path to the compusib bash repo checkout. Exported as BASH_REPO_ROOT via ~/.bashrc.d/005_BASH_REPO_ROOT_env.sh, and if <path>/bin/bashrc exists it is run as `bin/bashrc enable --all` during postAttachCommand."
        }
    },
    "postAttachCommand": "bash -c '[ -f ~/.bashrc.d/000_CONTAINER_WORKSPACE_FOLDER_env.sh ] || echo \"export CONTAINER_WORKSPACE_FOLDER=${containerWorkspaceFolder}\" > ~/.bashrc.d/000_CONTAINER_WORKSPACE_FOLDER_env.sh; . ~/.bashrc.d/005_BASH_REPO_ROOT_env.sh 2>/dev/null || true; { [ -x \"$BASH_REPO_ROOT/bin/bashrc\" ] && \"$BASH_REPO_ROOT/bin/bashrc\" enable --all; } || true'"
}
