{
    "settings_bridge_disabled": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "installSettingsBridge": false
            }
        }
    },
    "marketplace_online": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "installSettingsBridge": false,
                "pluginMarketplaces": "compusib|git@github.com:compusib/ai.git|/tmp/compusib-no-marketplace"
            }
        }
    },
    "marketplace_mounted": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "installSettingsBridge": false,
                "pluginMarketplaces": "compusib|git@github.com:compusib/ai.git|/tmp/compusib-marketplace"
            }
        }
    },
    "marketplace_multi": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "installSettingsBridge": false,
                "claudePlugins": "base-stack@compusib widget@partner",
                "pluginMarketplaces": "compusib|git@github.com:compusib/ai.git|/tmp/compusib-multi partner|git@github.com:partner/plugins.git"
            }
        }
    },
    "settings_bridge_local": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "settingsBridgeRepoPath": "/tmp/sb-local-tree",
                "settingsBridgeRepo": "/tmp/sb-no-remote-repo"
            }
        }
    },
    "settings_bridge_remote": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "claude": {
                "settingsBridgeRepoPath": "/tmp/sb-no-local-tree",
                "settingsBridgeRepo": "/tmp/sb-seed-repo"
            }
        }
    }
}
